{
  "mcpServers": {
    "akshare": {
      "type": "stdio",
      "command": "python3",
      "args": ["run_server.py", "akshare-mcp"]
    },
    "ifind": {
      "type": "stdio",
      "command": "python3",
      "args": ["run_server.py", "ifind-mcp"],
      "env": {
        "IFIND_AUTH_TOKEN": "${IFIND_AUTH_TOKEN}"
      }
    },
    "china-news": {
      "type": "stdio",
      "command": "python3",
      "args": ["run_server.py", "china-news-mcp"]
    },
    "wind": {
      "type": "stdio",
      "command": "python3",
      "args": ["run_server.py", "wind-mcp"],
      "env": {
        "WIND_API_KEY": "${WIND_API_KEY}"
      }
    }
  }
}
