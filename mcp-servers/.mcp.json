{
  "mcpServers": {
    "akshare": {
      "type": "stdio",
      "command": "python3",
      "args": ["akshare-mcp/server.py"]
    },
    "ifind": {
      "type": "stdio",
      "command": "python3",
      "args": ["ifind-mcp/server.py"],
      "env": {
        "IFIND_AUTH_TOKEN": "${IFIND_AUTH_TOKEN}"
      }
    },
    "china-news": {
      "type": "stdio",
      "command": "python3",
      "args": ["china-news-mcp/server.py"]
    },
    "wind": {
      "type": "stdio",
      "command": "python3",
      "args": ["wind-mcp/server.py"],
      "env": {
        "WIND_API_KEY": "${WIND_API_KEY}"
      }
    }
  }
}
